diff --git a/src/kernel/pagecache.c b/src/kernel/pagecache.c
index 9e3606c7..a4673135 100644
--- a/src/kernel/pagecache.c
+++ b/src/kernel/pagecache.c
@@ -2104,8 +2104,16 @@ closure_function(1, 1, boolean, pagecache_page_release,
     pagecache_lock_state(pc);
     if (!pp->evicted)
         pagecache_page_release_locked(pc, pp, false);
-    /* a pagecache node being released means no outstanding page references are possible */
-    assert(page_state(pp) == PAGECACHE_PAGESTATE_FREE);
+    /* A pagecache node being released should mean no outstanding page
+     * references are possible. Some sandbox 9p teardown paths can still hold a
+     * transient mapping/page reference while the VM is already exiting; don't
+     * turn that into a kernel panic. Leave the page behind for the dying VM
+     * instead of deallocating memory still referenced elsewhere.
+     */
+    if (page_state(pp) != PAGECACHE_PAGESTATE_FREE) {
+        pagecache_unlock_state(pc);
+        return true;
+    }
     pagelist_remove(&pc->free, pp);
     pagecache_unlock_state(pc);
     deallocate(pc->pp_heap, pp, sizeof(*pp));
