{
  "name": "ant-desktop",
  "version": "0.1.2",
  "description": "Build native desktop applications with Ant",
  "keywords": [
    "ant",
    "desktop",
    "macos",
    "chromium",
    "native",
    "appkit",
    "javascript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theMackabu/ant.git",
    "directory": "packages/desktop"
  },
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "bin": {
    "ant-desktop": "app/bin/ant-desktop.js"
  },
  "scripts": {
    "build": "ant scripts/build.js",
    "package": "ant scripts/package-platform.cjs",
    "release": "node scripts/publish.js",
    "version:set": "node scripts/set-version.js",
    "example:start": "ant app/bin/ant-desktop.js dev --app-dir tests/examples",
    "example:package": "ant app/bin/ant-desktop.js package --app-dir tests/examples --overwrite"
  },
  "files": [
    "app/bin/",
    "config.js",
    "index.js",
    "platforms.json",
    "README.md"
  ],
  "optionalDependencies": {
    "ant-desktop-darwin-arm64": "0.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
