{
  "name": "@antjs.org/colony",
  "version": "0.0.1",
  "description": "Deploy Ant apps to ants.page (console.antjs.org)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theMackabu/ant.git"
  },
  "bin": {
    "colony": "dist/bin.js"
  },
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "rimraf dist && tsc",
    "cli": "ant src/bin.ts",
    "test": "npm run build && node --test test/*.test.cjs",
    "prepack": "npm run build"
  },
  "keywords": [
    "ants.page",
    "console.antjs.org",
    "ant",
    "deploy",
    "edge"
  ],
  "homepage": "https://console.antjs.org",
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "rimraf": "^5.0.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "rolldown": "^1.1.3",
    "smol-toml": "^1.7.0"
  }
}
