+closure_func_basic(vqfinish, void, virtio_sock_event_complete,
+                   u64 len)
+{
+    virtio_sock_eventbuf eventbuf = struct_from_field(closure_self(), virtio_sock_eventbuf, complete);
+    virtio_sock vs = eventbuf->vs;
+
+    if (len >= sizeof(eventbuf->event)) {
+        switch (eventbuf->event.id) {
+        case VIRTIO_VSOCK_EVENT_TRANSPORT_RESET:
+            virtio_sock_debug("transport reset event");
+            break;
+        default:
+            virtio_sock_debug("unknown event %d", eventbuf->event.id);
+            break;
+        }
+    }
+
+    dealloc_unmap(vs->backed, eventbuf, eventbuf->phys, sizeof(*eventbuf));
+    if (!virtio_sock_eventq_submit(vs))
+        virtio_sock_debug("failed to resubmit event queue buffer");
+}
+
+static boolean virtio_sock_eventq_submit(virtio_sock vs)
+{
+    virtqueue vq = vs->eventq;
+    u64 phys;
+    virtio_sock_eventbuf eventbuf = alloc_map(vs->backed, sizeof(*eventbuf), &phys);
+    if (eventbuf == INVALID_ADDRESS)
+        return false;
+    eventbuf->vs = vs;
+    eventbuf->phys = phys;
+    eventbuf->event.id = 0;
+
+    vqmsg m = allocate_vqmsg(vq);
+    if (m == INVALID_ADDRESS) {
+        dealloc_unmap(vs->backed, eventbuf, phys, sizeof(*eventbuf));
+        return false;
+    }
+
+    vqmsg_push(vq, m, phys + offsetof(virtio_sock_eventbuf, event),
+               sizeof(eventbuf->event), true);
+    vqmsg_commit(vq, m, init_closure_func(&eventbuf->complete, vqfinish,
+                                          virtio_sock_event_complete));
+    return true;
+}
