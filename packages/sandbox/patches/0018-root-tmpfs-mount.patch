         storage_check_if_ready();
 }
 
+static void storage_mount_tmpfs(void)
+{
+    if (!storage.root_fs || storage.tmpfs_mounted)
+        return;
+
+    filesystem root_fs = storage.root_fs;
+    int fss = filesystem_mkdirpath(root_fs, 0, ss("/tmp"), false);
+    if ((fss != 0) && (fss != -EEXIST)) {
+        msg_err("storage: failed to create /tmp mount point: %s", string_from_errno(-fss));
+        return;
+    }
+
+    tuple root = filesystem_getroot(root_fs);
+    tuple mount_dir_t;
+    filesystem lookup_fs = root_fs;
+    fss = filesystem_get_node(&lookup_fs, root_fs->get_inode(root_fs, root), ss("/tmp"),
+                              FS_NODE_FOLLOW, &mount_dir_t, 0, 0);
+    if (fss != 0) {
+        msg_err("storage: /tmp mount point not found: %s", string_from_errno(-fss));
+        return;
+    }
+
+    boolean valid_mount_dir = (lookup_fs == root_fs) && (mount_dir_t != root) && children(mount_dir_t);
+    inode mount_dir = lookup_fs->get_inode(lookup_fs, mount_dir_t);
+    filesystem_put_node(lookup_fs, mount_dir_t);
+    if (!valid_mount_dir) {
+        msg_err("storage: invalid /tmp mount point");
+        return;
+    }
+
+    volume v = allocate(storage.h, sizeof(*v));
+    if (v == INVALID_ADDRESS) {
+        msg_err("storage: failed to track /tmp tmpfs mount");
+        return;
+    }
+    zero(v, sizeof(*v));
+
+    filesystem tmp_fs = tmpfs_new();
+    if (tmp_fs == INVALID_ADDRESS) {
+        msg_err("storage: failed to create /tmp tmpfs");
+        deallocate(storage.h, v, sizeof(*v));
+        return;
+    }
+
+    fss = filesystem_mount(root_fs, mount_dir, tmp_fs);
+    if (fss != 0) {
+        msg_err("storage: failed to mount /tmp tmpfs: %s", string_from_errno(-fss));
+        filesystem_release(tmp_fs);
+        deallocate(storage.h, v, sizeof(*v));
+        return;
+    }
+
+    runtime_memcpy(v->label, "tmpfs", sizeof("tmpfs"));
+    v->label_len = sstring_from_cstring(v->label, VOLUME_LABEL_MAX_LEN).len;
+    v->attach_id = -1;
+    v->fs = tmp_fs;
+    v->mount_dir = mount_dir;
+
+    storage_lock();
+    list_push_back(&storage.volumes, &v->l);
+    storage.tmpfs_mounted = true;
+    notify_mount_change_locked();
+    storage_unlock();
+}
