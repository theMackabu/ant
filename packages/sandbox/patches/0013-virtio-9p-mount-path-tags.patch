+static buffer storage_copy_mount_path(buffer path)
+{
+    bytes len = buffer_length(path);
+    buffer copy = allocate_buffer(storage.h, len);
+    if (copy == INVALID_ADDRESS)
+        return INVALID_ADDRESS;
+    runtime_memcpy(buffer_ref(copy, 0), buffer_ref(path, 0), len);
+    buffer_produce(copy, len);
+    return copy;
+}
+
+static symbol storage_attach_id_symbol(int attach_id)
+{
+    char name[32];
+    rsnprintf(name, sizeof(name), "%%%d", attach_id);
+    return intern(alloca_wrap_buffer(name, sstring_from_cstring(name, sizeof(name)).len));
+}
+
+boolean storage_mount_attach_id(int attach_id, buffer path)
+{
+    buffer persistent_path = storage_copy_mount_path(path);
+    if (persistent_path == INVALID_ADDRESS)
+        return false;
+
+    tuple new_mounts = 0;
+    if (!storage.mounts) {
+        new_mounts = allocate_tuple();
+        if (new_mounts == INVALID_ADDRESS) {
+            deallocate_buffer(persistent_path);
+            return false;
+        }
+    }
+
+    symbol attach = storage_attach_id_symbol(attach_id);
+    boolean mounted = false;
+    storage_lock();
+    if (!storage.mounts)
+        storage.mounts = new_mounts;
+    set(storage.mounts, attach, persistent_path);
+    list_foreach(&storage.volumes, e) {
+        volume v = struct_from_list(e, volume, l);
+        if (v->attach_id == attach_id) {
+            if (!v->fs && !v->mounting)
+                volume_mount(v, persistent_path);
+            mounted = true;
+            break;
+        }
+    }
+    storage_unlock();
+    if (mounted)
+        storage_check_if_ready();
+    return mounted;
+}
+
 static void storage_io_sg(block_io op, sg_list sg, range blocks, status_handler completion)
 {
     merge m = allocate_merge(storage.h, completion);
@@ -228,6 +291,11 @@ void storage_set_root_fs(filesystem root_fs)
 {
     storage.root_fs = root_fs;
     fs_set_path_helper(get_root_fs, storage_get_mountpoint);
+    storage_lock();
