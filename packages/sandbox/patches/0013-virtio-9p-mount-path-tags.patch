 }
 
 closure_func_basic(binding_handler, boolean, storage_set_mountpoints_each,
@@ -245,13 +313,33 @@ closure_func_basic(binding_handler, boolean, storage_set_mountpoints_each,
     return true;
 }
 
+static void storage_apply_mountpoints_locked(void)
+{
+    if (!storage.mounts)
+        return;
+    storage.mounting = true;
+    iterate(storage.mounts, stack_closure_func(binding_handler, storage_set_mountpoints_each));
+    storage.mounting = false;
+}
+
+closure_func_basic(binding_handler, boolean, storage_merge_mountpoints_each,
+                   value k, value path)
+{
+    assert(is_symbol(k));
+    assert(is_string(path));
+    set(storage.mounts, k, path);
+    return true;
+}
+
 void storage_set_mountpoints(tuple mounts)
 {
     storage_lock();
-    storage.mounts = mounts;
-    storage.mounting = true;
-    iterate(mounts, stack_closure_func(binding_handler, storage_set_mountpoints_each));
-    storage.mounting = false;
+    if (storage.mounts && storage.mounts != mounts) {
+        iterate(mounts, stack_closure_func(binding_handler, storage_merge_mountpoints_each));
+    } else {
+        storage.mounts = mounts;
+    }
+    storage_apply_mountpoints_locked();
     storage_unlock();
     storage_check_if_ready();
 }
