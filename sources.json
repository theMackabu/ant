{
  "engine": {
    "patterns": ["src/*.c", "src/gc/*.c", "src/highlight/*.c", "src/esm/*.c", "src/cli/*.c", "src/modules/*.c", "src/streams/*.c", "src/silver/*.c"],
    "exclude": ["src/main.c", "src/watch.c"]
  },
  "library": {
    "patterns": ["src/*.c", "src/gc/*.c", "src/highlight/*.c", "src/esm/*.c", "src/modules/*.c", "src/streams/*.c", "src/silver/*.c"],
    "exclude": ["src/main.c", "src/watch.c"]
  },
  "core": {
    "patterns": ["src/core/**/*.ts"],
    "exclude": ["src/core/index.ts"]
  }
}
