{
  "engine": {
    "patterns": [
      "src/*.c",
      "src/*.cc",
      "src/gc/*.c",
      "src/readline/*.c",
      "src/highlight/*.c",
      "src/esm/*.c",
      "src/cli/*.c",
      "src/sandbox/*.c",
      "src/inspector/*.c",
      "src/modules/*.c",
      "src/streams/*.c",
      "src/silver/*.c",
      "src/http/*.c",
      "src/net/*.c"
    ],
    "exclude": ["src/main.c"]
  },
  "library": {
    "files": ["src/cli/version.c"],
    "patterns": [
      "src/*.c",
      "src/*.cc",
      "src/gc/*.c",
      "src/readline/*.c",
      "src/highlight/*.c",
      "src/esm/*.c",
      "src/sandbox/*.c",
      "src/inspector/*.c",
      "src/modules/*.c",
      "src/streams/*.c",
      "src/silver/*.c",
      "src/http/*.c",
      "src/net/*.c"
    ],
    "exclude": ["src/main.c"]
  },
  "sandbox_backend": {
    "sections": {
      "shared": {
        "files": [
          "src/sandbox/backends/shared/common.c",
          "src/sandbox/backends/shared/nat.c",
          "src/sandbox/backends/shared/net_packets.c",
          "src/sandbox/backends/shared/pci.c",
          "src/sandbox/backends/shared/virtio.c",
          "src/sandbox/backends/shared/virtio_9p.c",
          "src/sandbox/backends/shared/virtio_blk.c",
          "src/sandbox/backends/shared/virtio_net.c",
          "src/sandbox/backends/shared/virtio_rng.c",
          "src/sandbox/backends/shared/virtio_vsock.c"
        ]
      },
      "darwin": {
        "files": ["src/sandbox/backends/darwin/backend.c"]
      },
      "darwin_hvf": {
        "files": [
          "src/sandbox/backends/darwin/fdt.c",
          "src/sandbox/backends/darwin/gic.c",
          "src/sandbox/backends/darwin/mmio.c",
          "src/sandbox/backends/darwin/uart.c"
        ]
      },
      "linux": {
        "files": [
          "src/sandbox/backends/linux/kvm_aarch64.c",
          "src/sandbox/backends/linux/kvm_common.c",
          "src/sandbox/backends/linux/kvm_unavailable.c",
          "src/sandbox/backends/linux/kvm_x86.c"
        ]
      },
      "windows": {
        "files": ["src/sandbox/backends/windows/backend.c"]
      }
    }
  },
  "core": {
    "patterns": ["src/core/**/*.ts"],
    "exclude": ["src/core/index.ts"]
  },
  "builtins": {
    "patterns": [
      "src/builtins/**/*.cts",
      "src/builtins/**/*.mts",
      "src/builtins/**/*.ts",
      "src/builtins/**/*.cjs",
      "src/builtins/**/*.mjs",
      "src/builtins/**/*.js"
    ],
    "exclude": []
  }
}
