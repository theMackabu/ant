+    if (req == NULL || !req->cancel_pending) return;
+
+    req->cancel_pending = false;
+    if (c->active == req) {
+        c->active = NULL;
+    }
+
+    req->resp.code = req->cancel_error;
+    if (req->resp.status) {
+        tlsuv__free(req->resp.status);
+    }
+    req->resp.status = req->cancel_status;
+    req->cancel_status = NULL;
