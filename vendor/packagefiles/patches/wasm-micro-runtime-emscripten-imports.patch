+static bool
+wasm_table_init_host_instance(wasm_table_t *table,
+                              const wasm_tabletype_t *table_type)
+{
+    uint32 max_size;
+    uint64 total_size;
+    WASMTableInstance *table_inst;
+
+    if (!table || !table_type || !table_type->val_type)
+        return false;
+
+    max_size = table_type->limits.max == wasm_limits_max_default
+                   ? WASM_C_API_DEFAULT_HOST_TABLE_MAX
+                   : table_type->limits.max;
+    if (max_size < table_type->limits.min)
+        max_size = table_type->limits.min;
+
+    total_size = offsetof(WASMTableInstance, elems)
+                 + (uint64)sizeof(table_elem_type_t) * max_size;
+    if (total_size > UINT32_MAX)
+        return false;
+
+    if (!(table_inst = malloc_internal(total_size)))
+        return false;
+
+#if WASM_ENABLE_GC == 0
+    memset(table_inst, -1, (uint32)total_size);
+#endif
+    if (!(table_inst->func_refs = malloc_internal(
+              (uint64)sizeof(WASMTableFuncRef) * max_size))) {
+        wasm_runtime_free(table_inst);
+        return false;
+    }
+    memset(table_inst->func_refs, 0,
+           (uint32)((uint64)sizeof(WASMTableFuncRef) * max_size));
+    table_inst->elem_type =
+        valkind_2_val_type_rt(wasm_valtype_kind(table_type->val_type));
+    table_inst->cur_size = table_type->limits.min;
+    table_inst->max_size = max_size;
+
+    table->host_table = table_inst;
+    table->own_host_table = true;
+    return true;
+}
+
+static bool
+wasm_table_reserve_host_instance(wasm_table_t *table, uint32 min_max_size)
+{
+    uint64 old_size, new_size, old_refs_size, new_refs_size;
+    WASMTableInstance *grown;
+    WASMTableFuncRef *grown_refs;
+
+    if (!table || !table->host_table)
+        return false;
+    if (table->host_table->max_size >= min_max_size)
+        return true;
+    if (table->inst_comm_rt)
+        return false;
+
+    old_size = offsetof(WASMTableInstance, elems)
+               + (uint64)sizeof(table_elem_type_t)
+                     * table->host_table->max_size;
+    new_size = offsetof(WASMTableInstance, elems)
+               + (uint64)sizeof(table_elem_type_t) * min_max_size;
+    if (new_size > UINT32_MAX)
+        return false;
+
+    old_refs_size =
+        (uint64)sizeof(WASMTableFuncRef) * table->host_table->max_size;
+    new_refs_size = (uint64)sizeof(WASMTableFuncRef) * min_max_size;
+    if (new_refs_size > UINT32_MAX)
+        return false;
+
+    if (!(grown_refs = wasm_runtime_realloc(table->host_table->func_refs,
+                                            (uint32)new_refs_size)))
+        return false;
+
+    memset((uint8 *)grown_refs + old_refs_size, 0,
+           (uint32)(new_refs_size - old_refs_size));
+    table->host_table->func_refs = grown_refs;
+
+    if (!(grown = wasm_runtime_realloc(table->host_table, (uint32)new_size)))
+        return false;
+
+#if WASM_ENABLE_GC == 0
+    memset((uint8 *)grown + old_size, -1, (uint32)(new_size - old_size));
+#else
+    memset((uint8 *)grown + old_size, 0, (uint32)(new_size - old_size));
+#endif
+    grown->func_refs = grown_refs;
+    grown->max_size = min_max_size;
+    table->host_table = grown;
+    return true;
+}
