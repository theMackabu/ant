+static bool
+wasm_valkind_to_val_type_rt(wasm_valkind_t kind, uint8 *val_type_rt)
+{
+    if (!val_type_rt)
+        return false;
+
+    switch (kind) {
+        case WASM_I32:
+            *val_type_rt = VALUE_TYPE_I32;
+            return true;
+        case WASM_I64:
+            *val_type_rt = VALUE_TYPE_I64;
+            return true;
+        case WASM_F32:
+            *val_type_rt = VALUE_TYPE_F32;
+            return true;
+        case WASM_F64:
+            *val_type_rt = VALUE_TYPE_F64;
+            return true;
+        case WASM_V128:
+            *val_type_rt = VALUE_TYPE_V128;
+            return true;
+        case WASM_FUNCREF:
+            *val_type_rt = VALUE_TYPE_FUNCREF;
+            return true;
+        case WASM_EXTERNREF:
+            *val_type_rt = VALUE_TYPE_EXTERNREF;
+            return true;
+        default:
+            return false;
+    }
+}
