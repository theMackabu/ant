+static bool
+interp_link_memory(const WASMModule *module_interp, uint16 memory_idx_rt,
+                   wasm_memory_t *import)
+{
+    WASMImport *imported_memory_interp = NULL;
+    WASMMemoryInstance *memory_inst = NULL;
+    uint32 actual_min, actual_max, required_max;
+
+    bh_assert(module_interp && import);
+    bh_assert(memory_idx_rt < module_interp->import_memory_count);
+    bh_assert(WASM_EXTERN_MEMORY == import->kind);
+
+    imported_memory_interp = module_interp->import_memories + memory_idx_rt;
+    bh_assert(imported_memory_interp);
+    bh_assert(imported_memory_interp->kind == IMPORT_KIND_MEMORY);
+
+    if (import->host_memory) {
+        memory_inst = import->host_memory;
+    }
+    else if (import->inst_comm_rt
+             && import->inst_comm_rt->module_type == Wasm_Module_Bytecode) {
+        WASMModuleInstance *module_inst = (WASMModuleInstance *)import->inst_comm_rt;
+        if (import->memory_idx_rt < module_inst->memory_count)
+            memory_inst = module_inst->memories[import->memory_idx_rt];
+    }
+
+    if (!memory_inst)
+        return false;
+
+    actual_min = memory_inst->cur_page_count;
+    actual_max = memory_inst->max_page_count;
+    required_max = imported_memory_interp->u.memory.mem_type.max_page_count;
+    if (actual_min < imported_memory_interp->u.memory.mem_type.init_page_count)
+        return false;
+    if (required_max != wasm_limits_max_default
+        && actual_max != wasm_limits_max_default && actual_max < required_max) {
+        return false;
+    }
+
+    imported_memory_interp->u.memory.import_memory_inst = memory_inst;
+    import->memory_idx_rt = memory_idx_rt;
+    return true;
+}
