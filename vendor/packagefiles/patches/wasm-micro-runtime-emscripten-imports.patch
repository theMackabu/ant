+static uint8
+valkind_2_val_type_rt(wasm_valkind_t kind)
+{
+    switch (kind) {
+        case WASM_FUNCREF:
+            return VALUE_TYPE_FUNCREF;
+        case WASM_EXTERNREF:
+            return VALUE_TYPE_EXTERNREF;
+        default:
+            return VALUE_TYPE_FUNCREF;
+    }
+}
