+static void ws_read_buffer_clear(tlsuv_websocket_t *ws) {
+    if (ws == NULL) return;
+    tlsuv__free(ws->read_buf);
+    ws->read_buf = NULL;
+    ws->read_len = 0;
+    ws->read_cap = 0;
