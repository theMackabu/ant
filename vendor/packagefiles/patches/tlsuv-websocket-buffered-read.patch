+                break;
+            }
+            cap *= 2;
+        }
+        char *next = tlsuv__realloc(ws->read_buf, cap);
+        if (next == NULL) return UV_ENOMEM;
+        ws->read_buf = next;
+        ws->read_cap = cap;
+    }
+
+    memcpy(ws->read_buf + ws->read_len, data, len);
+    ws->read_len = need;
+    return 0;
