+
+static int ws_read_buffer_append(tlsuv_websocket_t *ws, const char *data, size_t len) {
+    if (ws == NULL || len == 0) return 0;
+    if (data == NULL || len > SIZE_MAX - ws->read_len) return UV_ENOMEM;
+
+    size_t need = ws->read_len + len;
+    if (need > ws->read_cap) {
+        size_t cap = ws->read_cap != 0 ? ws->read_cap : 8192;
+        while (cap < need) {
+            if (cap > SIZE_MAX / 2) {
